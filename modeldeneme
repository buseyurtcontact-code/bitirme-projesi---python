def make_sample_weights(index, halflife_days=365):              # Zaman serisindeki örneklere üstel azalan ağırlık atayan fonksiyon
    latest   = index.max()                                      # En son tarihi bul
    days_ago = np.array((latest - index).days, dtype=float)    # Her örneğin en son tarihten kaç gün önce olduğunu hesapla
    weights  = np.exp(-days_ago * math.log(2) / halflife_days) # Üstel azalan ağırlık formülünü uygula
    return weights / weights.mean()                             # Ağırlıkları ortalamaları 1 olacak şekilde normalize et

def make_sequences(X, seq_len):                                 # Kayan pencere yöntemiyle 3 boyutlu sekans dizisi oluşturan fonksiyon
    """Vectorised sliding window using numpy strides — no Python loop."""
    if seq_len <= 1:                                            # Sekans uzunluğu 1 veya daha azsa
        return X[:, np.newaxis, :]                              # Her satırı tek adımlı sekans olarak döndür
    n, n_feat = X.shape                                         # Satır sayısı ve özellik sayısını al
    shape   = (n - seq_len + 1, seq_len, n_feat)               # Çıktı dizisinin şeklini hesapla
    strides = (X.strides[0], X.strides[0], X.strides[1])      # Bellek adım bilgilerini kayan pencere için ayarla
    return np.lib.stride_tricks.as_strided(X, shape=shape, strides=strides).copy()  # Kopyalanan stride tabanlı görünümü döndür

def build_and_train(model_type, X_tr, y_tr, X_te, seq_len, sample_weight=None):  # Model oluşturup eğiten ve test tahminini döndüren fonksiyon
    from tensorflow.keras.layers import GRU, LSTM              # GRU ve LSTM katmanlarını içe aktar

    random.seed(RANDOM_SEED)            # Tekrar üretilebilirlik için random tohumunu sıfırla
    np.random.seed(RANDOM_SEED)         # NumPy tohumunu sıfırla
    tf.random.set_seed(RANDOM_SEED)     # TensorFlow tohumunu sıfırla

    n_feat = X_tr.shape[-1]             # Özellik sayısını girdi verisinin son boyutundan al

    if model_type == "Dense":           # Seçilen model tipi Dense (tam bağlı) ise
        m = Sequential([
            Input(shape=(seq_len, n_feat)),             # Girdi katmanı: (sekans_uzunluğu, özellik_sayısı)
            Flatten(),                                   # 2D sekansı 1D vektöre düzleştir
            Dense(64, activation="relu"),               # 64 nöronlu gizli katman, ReLU aktivasyonu
            Dense(max(8, 64 // 8), activation="relu"),  # Daralan ikinci gizli katman
            Dense(1)                                     # Tek nöronlu çıktı katmanı (regresyon)
        ])
    elif model_type == "GRU":           # Seçilen model tipi GRU ise
        m = Sequential([
            Input(shape=(seq_len, n_feat)),             # Girdi katmanı
            GRU(64, return_sequences=False),            # 64 birimli GRU katmanı, sadece son adımı döndür
            Dense(max(8, 64 // 8), activation="relu"),  # Tam bağlı gizli katman
            Dense(1)                                     # Çıktı katmanı
        ])
    elif model_type == "LSTM":          # Seçilen model tipi LSTM ise
        m = Sequential([
            Input(shape=(seq_len, n_feat)),             # Girdi katmanı
            LSTM(64, return_sequences=False),           # 64 birimli LSTM katmanı, sadece son adımı döndür
            Dense(max(8, 64 // 8), activation="relu"),  # Tam bağlı gizli katman
            Dense(1)                                     # Çıktı katmanı
        ])

    m.compile(optimizer="adam", loss="mse")                                             # Modeli Adam optimizer ve MSE kaybı ile derle
    es = EarlyStopping(monitor="val_loss", patience=8, restore_best_weights=True)       # Doğrulama kaybı 8 epoch iyileşmezse dur, en iyi ağırlıkları geri yükle

    Xtr, Xte = X_tr, X_te              # Eğitim ve test verisine kısayol değişkenleri ata
    if sample_weight is not None:       # Örnek ağırlığı verilmişse
        val_cut = int(len(Xtr) * 0.8)  # %80 eğitim, %20 doğrulama bölümü belirle
        sw_t    = sample_weight[:val_cut]  # Sadece eğitim kısmına ait ağırlıkları al
        m.fit(Xtr[:val_cut], y_tr[:val_cut],
              sample_weight=sw_t,
              validation_data=(Xtr[val_cut:], y_tr[val_cut:]),
              epochs=100, batch_size=32, callbacks=[es], verbose=0)  # Modeli ağırlıklı örneklerle eğit
    else:                               # Örnek ağırlığı verilmemişse
        m.fit(Xtr, y_tr, validation_split=0.2,
              epochs=100, batch_size=32, callbacks=[es], verbose=0)  # Modeli standart doğrulama bölünmesiyle eğit

    return m.predict(Xte, verbose=0)    # Test verisi üzerinde tahmin yap ve döndür

def make_dynamic_wf_windows(full_df, start_date, months_step):  # Kayan ileri doğrulama (walk-forward) pencereleri oluşturan fonksiyon
    windows = []                                                  # Pencereleri tutacak boş liste
    current_test_start = pd.Timestamp(start_date)                # İlk test penceresi başlangıç tarihi
    max_date = full_df.index.max()                               # Veri setinin en son tarihi
    while current_test_start < max_date:                         # Test penceresi veri sonuna ulaşana kadar döngü
        current_test_end = current_test_start + pd.DateOffset(months=months_step)  # Test penceresi bitiş tarihi
        train_slice = full_df[full_df.index < current_test_start]                  # Test başlangıcından önceki tüm veri eğitim
        test_slice  = full_df[(full_df.index >= current_test_start) &
                               (full_df.index < current_test_end)]                 # Mevcut test penceresi
        if len(test_slice) > 0 and len(train_slice) > 60:                          # Yeterli veri varsa
            windows.append((train_slice, test_slice))                               # Pencereyi listeye ekle
        current_test_start = current_test_end                                       # Sonraki pencereye geç
    return windows                                                                  # Tüm pencereleri döndür

