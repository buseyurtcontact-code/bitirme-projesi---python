            # Interaction features
            for station in weather_stations:                            # Her hava istasyonu için etkileşim özelliği oluştur
                prcp_col = f"prcp_{station}"                            # Yağış sütun adı
                if prcp_col in df.columns:                              # Yağış sütunu mevcutsa
                    df[f"rain_x_level_{station}"] = df[prcp_col] * df[f"lag_{base_lag}"]  # Yağış × doluluk etkileşim terimi

            # Seasonal
            df["month_sin"] = np.sin(2 * np.pi * df.index.month / 12)        # Ay bilgisini sinüs ile döngüsel kodla
            df["month_cos"] = np.cos(2 * np.pi * df.index.month / 12)        # Ay bilgisini kosinüs ile döngüsel kodla
            df["doy_sin"]   = np.sin(2 * np.pi * df.index.dayofyear / 365)   # Yılın günü bilgisini sinüs ile kodla
            df["doy_cos"]   = np.cos(2 * np.pi * df.index.dayofyear / 365)   # Yılın günü bilgisini kosinüs ile kodla

            # Multi-horizon targets
            target_cols_multi = [f"target_{h}" for h in TARGET_HORIZONS]  # Her horizon için hedef sütun adları listesi
            for h in TARGET_HORIZONS:                                       # Her tahmin horizonu için
                df[f"target_{h}"] = df[target_col].shift(-h)               # h gün sonrasını hedef olarak ekle (gelecek kaydırma)

            df = df.ffill().bfill().dropna()  # Kalan NaN'ları önce ileri sonra geri doldur, ardından NaN içeren satırları at

            dam_start = df_raw[target_col].first_valid_index()  # Bu barajın verisinin başladığı ilk geçerli tarihi bul
            if dam_start is None:                                # Baraj için hiç veri yoksa
                continue                                         # Bu barajı atla
            DAM_END_DATES = {"Guzelhisar": pd.Timestamp("2025-11-19")}  # Bazı barajlar için özel bitiş tarihleri
            dam_end = DAM_END_DATES.get(dam, pd.Timestamp("2025-11-30"))  # Barajın bitiş tarihini al, varsayılan 2025-11-30
            df = df[(df.index >= pd.Timestamp(dam_start)) & (df.index <= dam_end)]  # Geçerli tarih aralığına kırp

            pre2023   = df[df.index.year < 2023]       # 2023 öncesi veriyi eğitim seti olarak ayır
            test_data = df[df.index.year >= 2023]      # 2023 ve sonrası veriyi test seti olarak ayır
            if len(test_data) == 0:                    # Test verisi yoksa
                continue                               # Bu barajı atla

            drop_from_X = [target_col] + target_cols_multi  # Girdi özelliklerinden çıkarılacak hedef sütunlar
            y_test      = test_data[target_cols_multi]       # Test setinin hedef değerleri

            STRATEGIES = [                                                                       # Strateji tanımları: ad ve eğitim kaynağı
                ("baseline",          pre2023,                                            ),     # Temel strateji: sadece 2023 öncesi veri
                ("walkfwd_expanding", make_dynamic_wf_windows(df, "2023-01-01", 6)),            # Genişleyen walk-forward: 6 aylık pencereler
            ]

        for halflife in HALFLIVES:                           # Her yarı ömür değeri için döngü
                for strategy_label, train_source in STRATEGIES:  # Her strateji için döngü
                    if strategy_label not in STRATEGIES_TO_RUN:  # Bu strateji çalıştırılacaklar listesinde değilse
                        continue                                  # Atla
                    is_walkfwd = strategy_label.startswith("walkfwd")  # Walk-forward stratejisi mi kontrol et

                    for model_type in MODEL_TYPES:                      # Her model tipi için döngü
                        # Skip if this combo is already done (checkpoint resume)
                        ck = (dam, strategy_label, model_type,
                                lag_name, seq_name, halflife, 64)       # Bu kombinasyon için benzersiz anahtar oluştur
                        if ck in done_combos:                           # Bu kombinasyon daha önce tamamlandıysa
                            run_counter += len(TARGET_HORIZONS)         # Sayacı horizon sayısı kadar artır
                            print(f"  [SKIP] {dam} {strategy_label} {model_type} "
                                    f"lag={lag_name} seq={seq_name} hl={halflife} hid={64}")  # Atlanan kombinasyonu yazdır
                            continue                                    # Sonraki kombinasyona geç

                        horizon_metrics = {}    # Bu kombinasyonun horizon bazındaki metriklerini tutacak sözlük

                        for h in TARGET_HORIZONS:                           # Her tahmin horizonu için döngü
                            run_counter += 1                                # Çalıştırma sayacını artır
                            h_lags        = lag_cfg[h]                     # Bu horizon için kullanılacak lag günleri
                            seq_len       = seq_cfg[h]                     # Bu horizon için sekans uzunluğu
                            target_col_h  = f"target_{h}"                  # Bu horizonun hedef sütun adı
                            label         = f"+{h}d"                       # Horizon etiketi (örn. "+7d")

                            lag_cols_h    = [f"lag_{l}" for l in h_lags]  # Bu horizon için kullanılacak lag sütunları
                            lag_cols_drop = [c for c in lag_cols_all if c not in lag_cols_h]  # Bu horizon için kullanılmayacak lag sütunları
                            drop_h        = drop_from_X + lag_cols_drop    # Bu horizonda girdi verisinden çıkarılacak tüm sütunlar

                            X_test_h = test_data.drop(
                                columns=[c for c in drop_h if c in test_data.columns])  # Test verisinden gereksiz sütunları çıkar

                            elapsed  = time.time() - start_time                              # Geçen süreyi hesapla
                            eta_secs = (elapsed / run_counter) * (total_runs - run_counter) if run_counter > 1 else 0  # Kalan tahmini süreyi hesapla
                            print(f"  [{run_counter}/{total_runs}] "
                                    f"lag={lag_name} seq={seq_name} hl={halflife} "
                                    f"hid={64} {strategy_label} {model_type} "
                                    f"{dam} {label}  "
                                    f"ETA {eta_secs/3600:.1f}h", end="  ", flush=True)  # İlerleme bilgisini yazdır

                            if is_walkfwd:                                                   # Walk-forward strateji ise
                                all_y_true_h, all_y_pred_h = [], []                         # Gerçek ve tahmin değerleri için boş listeler
                                for train_slice, test_slice in train_source:                 # Her walk-forward penceresi için
                                    X_tr_h = train_slice.drop(columns=[c for c in drop_h if c in train_slice.columns])  # Eğitim özellik matrisi
                                    y_tr_h = train_slice[[target_col_h]]                    # Eğitim hedef vektörü
                                    X_te_h = test_slice.drop(columns=[c for c in drop_h if c in test_slice.columns])   # Test özellik matrisi
                                    y_te_h = test_slice[[target_col_h]]                     # Test hedef vektörü

                                    scaler_x = MinMaxScaler()   # Özellikler için normalleştirici oluştur
                                    scaler_y = MinMaxScaler()   # Hedef için normalleştirici oluştur
                                    X_tr_sc  = scaler_x.fit_transform(X_tr_h)   # Eğitim özelliklerini normalleştir ve fit et
                                    y_tr_sc  = scaler_y.fit_transform(y_tr_h.values)  # Eğitim hedefini normalleştir ve fit et
                                    X_te_sc  = scaler_x.transform(X_te_h)       # Test özelliklerini eğitim scaler ile normalleştir

                                    X_tr_seq = make_sequences(X_tr_sc, seq_len)  # Eğitim verisi için sekanslar oluştur
                                    X_te_seq = make_sequences(X_te_sc, seq_len)  # Test verisi için sekanslar oluştur
                                    y_tr_seq = y_tr_sc[seq_len - 1:]             # Sekans oluşturmanın kaybettiği başlangıç satırlarını at

                                    sw = make_sample_weights(
                                        train_slice.index[seq_len - 1:],
                                        halflife_days=halflife)                  # Eğitim örnekleri için zamana dayalı ağırlıkları hesapla

                                    pred_sc = build_and_train(
                                        model_type, X_tr_seq, y_tr_seq, X_te_seq,
                                        seq_len=seq_len,
                                        sample_weight=sw)                        # Modeli eğit ve normalize tahmin al
                                    pred_us = scaler_y.inverse_transform(pred_sc)  # Tahmini orijinal ölçeğe geri dönüştür

                                    all_y_true_h.append(y_te_h.values[seq_len - 1:])  # Bu pencerenin gerçek değerlerini ekle
                                    all_y_pred_h.append(pred_us)                       # Bu pencerenin tahmin değerlerini ekle

                                y_true_h = np.vstack(all_y_true_h).ravel()  # Tüm pencerelerin gerçek değerlerini tek diziye birleştir
                                y_pred_h = np.vstack(all_y_pred_h).ravel()  # Tüm pencerelerin tahminlerini tek diziye birleştir

                            else:                                                                    # Temel (baseline) strateji ise
                                if len(pre2023) < seq_len + 10:                                     # Eğitim verisi yetersizse
                                    print(f"skip (too few rows)")                                   # Uyarı yazdır
                                    continue                                                         # Bu kombinasyonu atla
                                X_tr_h = pre2023.drop(columns=[c for c in drop_h if c in pre2023.columns])  # 2023 öncesi eğitim özellik matrisi
                                y_tr_h = pre2023[[target_col_h]]                                    # 2023 öncesi eğitim hedef vektörü

                                sc_X = MinMaxScaler()               # Özellikler için normalleştirici
                                sc_y = MinMaxScaler()               # Hedef için normalleştirici
                                X_tr_sc = sc_X.fit_transform(X_tr_h)  # Eğitim özelliklerini normalleştir
                                y_tr_sc = sc_y.fit_transform(y_tr_h.values)  # Eğitim hedefini normalleştir
                                X_te_sc = sc_X.transform(X_test_h)  # Test özelliklerini normalleştir

                                X_tr_seq = make_sequences(X_tr_sc, seq_len)  # Eğitim sekansları
                                X_te_seq = make_sequences(X_te_sc, seq_len)  # Test sekansları
                                y_tr_seq = y_tr_sc[seq_len - 1:]             # Hedef dizisini sekans kaybına göre hizala

                                pred_sc  = build_and_train(
                                    model_type, X_tr_seq, y_tr_seq, X_te_seq,
                                    seq_len=seq_len)                         # Modeli eğit ve normalize tahmin al
                                y_pred_h = sc_y.inverse_transform(pred_sc).ravel()      # Tahmini orijinal ölçeğe çevir
                                y_true_h = y_test[target_col_h].values[seq_len - 1:]    # Karşılık gelen gerçek test değerleri

                            y_pred_h = np.clip(y_pred_h, 0, 100)                         # Tahminleri [0, 100] aralığına sınırla
                            rmse_h   = np.sqrt(mean_squared_error(y_true_h, y_pred_h))   # RMSE (kök ortalama kare hata) hesapla
                            mae_h    = mean_absolute_error(y_true_h, y_pred_h)            # MAE (ortalama mutlak hata) hesapla
                            r2_h     = r2_score(y_true_h, y_pred_h)                      # R² (belirtme katsayısı) hesapla
                            horizon_metrics[label] = {"rmse": rmse_h, "mae": mae_h, "r2": r2_h}  # Bu horizonun metriklerini kaydet
                            print(f"R²={r2_h:.4f}", flush=True)                          # R² değerini konsola yazdır

                        if len(horizon_metrics) == 3:      # Tüm 3 horizon için metrikler hesaplandıysa
                            results_all.append({            # Sonuçlar listesine bu kombinasyonun tüm metriklerini ekle
                                "Dam":          dam,
                                "Strategy":     strategy_label,
                                "Model":        model_type,
                                "LagConfig":    lag_name,
                                "SeqConfig":    seq_name,
                                "Halflife":     halflife,
                                "HiddenSize":   64,
                                "RMSE +7d (%)": round(horizon_metrics["+7d"]["rmse"],  2),   # 7 günlük RMSE
                                "MAE +7d (%)":  round(horizon_metrics["+7d"]["mae"],   2),   # 7 günlük MAE
                                "R2 +7d":       round(horizon_metrics["+7d"]["r2"],    4),   # 7 günlük R²
                                "RMSE +14d (%)":round(horizon_metrics["+14d"]["rmse"], 2),  # 14 günlük RMSE
                                "MAE +14d (%)": round(horizon_metrics["+14d"]["mae"],  2),  # 14 günlük MAE
                                "R2 +14d":      round(horizon_metrics["+14d"]["r2"],   4),  # 14 günlük R²
                                "RMSE +30d (%)":round(horizon_metrics["+30d"]["rmse"], 2),  # 30 günlük RMSE
                                "MAE +30d (%)": round(horizon_metrics["+30d"]["mae"],  2),  # 30 günlük MAE
                                "R2 +30d":      round(horizon_metrics["+30d"]["r2"],   4),  # 30 günlük R²
                            })

                            # Mark done and save checkpoint after every completed combo
                            done_combos.add(ck)                              # Tamamlanan kombinasyonu kümeye ekle
                            pd.DataFrame(results_all).to_csv(
                                f"{OUT_DIR}/search_results_intermediate.csv", index=False)  # Ara sonuçları CSV'ye kaydet (kontrol noktası)

